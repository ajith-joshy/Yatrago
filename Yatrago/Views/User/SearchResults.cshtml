@model List<YatraGo.Models.Bus>

@{
    Layout = "_UserLayout";
}

<div class="available-buses-container">

    <h1>
        Available Buses
    </h1>

    <div class="table-container">

        <table class="bus-table">

            <thead>

                <tr>

                    <th>Bus Name</th>

                    <th>Bus Type</th>

                    <th>Source</th>

                    <th>Destination</th>

                    <th>Departure</th>

                    <th>Arrival</th>

                    <th>Fare</th>

                    <th>Available Seats</th>
    
                    <th>Action</th>

                </tr>

            </thead>

            <tbody>

                @if (Model.Count > 0)
                {
                    @foreach (var bus in Model)
                    {
                        <tr>

                            <td>@bus.BusName</td>

                            <td>@bus.BusType</td>

                            <td>@bus.Source</td>

                            <td>@bus.Destination</td>

                            <td>@bus.DepartureTime</td>

                            <td>@bus.ArrivalTime</td>

                            <td>₹ @bus.FareAmount</td>

                            <td>@bus.AvailableSeats</td>

                            <td>

                                <a asp-action="SelectSeats"
                                   asp-controller="User"
                                   asp-route-busId="@bus.BusId"
                                   asp-route-journeyDate="@Convert.ToDateTime(ViewBag.JourneyDate).ToString("yyyy-MM-dd")"
                                   class="seat-btn">

                                    Select Seats

                                </a>

                            </td>

                        </tr>
                    }
                }

                else
                {
                    <tr>

                        <td colspan="8"
                            class="no-bus">

                            No buses available.

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>