@model YatraGo.Models.User
@await Html.PartialAsync("_Navbar")
<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
    <link rel="stylesheet" href="~/css/signup.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <meta charset="utf-8" />
    <title>Signup</title>
</head>

<body>
    <div class="container">
        <h1 style="text-align:center; margin-bottom:20px;">Signup</h1>
        @if (ViewBag.Message != null)
        {
            <p style="
                color:red;
                text-align:center;
                margin-bottom:15px;
                ">
                @ViewBag.Message
            </p>
        }
        <form id="signup" method="post"
              enctype="multipart/form-data"
              asp-action="Signup"
              asp-controller="Account" onsubmit="return validateForm()">

            <div class="form-group">
                <label>First Name</label>
                <input type="text"
                       id="firstName"
                       name="FirstName"
                       value="@Model?.FirstName"
                       onblur="validateFirstName(); checkFormValidity()">
                <span class="error"
                      id="firstNameError">
                </span>
            </div>

            <div class="form-group">
                <label>Last Name</label>
                <input type="text"
                       id="lastName"
                       name="LastName"
                       value="@Model?.LastName"
                       onblur="validateLastName(); checkFormValidity()">
                <span class="error"
                      id="lastNameError">
                </span>
            </div>

            <div class="form-group">
                <label>Address</label>
                <textarea id="address"
                          name="Address"
                          onblur="validateAddress();checkFormValidity()">@Model?.Address</textarea>
                <span class="error"
                  id="addressError">
                </span>
            </div>

            <div class="form-group">
                <label>Username</label>
                <input type="text" id="username" name="Username"
                       value="@Model?.Username"
                       onblur="validateUsername();checkFormValidity()">
                <span class="error" id="usernameError"></span>
            </div>

            <div class="form-group">
                <label>Date of Birth</label>
                <input type="date" id="date" name="DOB"
                       value="@(Model?.DOB.ToString("yyyy-MM-dd"))"
                       onblur="validateDOB();checkFormValidity()">
                <span class="error" id="DOBError"></span>
            </div>

            <div class="form-group" id="genderContainer">
                <label>Gender</label>
                <input type="radio" name="Gender" value="Male"
                       onchange="validateGender();checkFormValidity()">
                Male
                <input type="radio" name="Gender" value="Female"
                       onchange="validateGender();checkFormValidity()">
                Female
                <input type="radio"
                       name="Gender"
                       value="Other"
                       onchange="validateGender();checkFormValidity()">
                Other
                <span class="error" id="genderError"></span>
            </div>
           
            <div class="form-group">
                <label>State</label>
                <select id="state"
                        name="StateId"
                        onchange="loadCities();validateState();checkFormValidity()">
                    <option value="">Select State</option>
                </select>
                <span class="error" id="stateError"></span>
            </div>

            <div class="form-group">
                <label>City</label>
                <select id="city" name="CityId"
                        onchange="validateCity();checkFormValidity()">
                    <option value="">Select City</option>
                </select>
                <span class="error" id="cityError"></span>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="text" id="email" name="Email"
                       value="@Model?.Email"
                       onblur="validateEmail();checkFormValidity()">
                <span class="error" id="emailError"></span>
            </div>

            <div class="form-group">
                <label>Phone Number</label>
                <input type="text" id="phone" name="Phone"
                       value="@Model?.Phone"
                       onblur="validatePhone();checkFormValidity()">
                <span class="error" id="phoneError"></span>
            </div>

            <div class="form-group">
                <label>Password</label>
                <div class="password-box">
                    <input type="password" id="password" name="Password"
                           oninput="validatePassword();enableConfirmPassword();checkFormValidity()">
                    <span class="eye" onclick="togglePassword('password')">👁</span>
                    <span id="passwordStrength"></span>
                </div>
                <span class="error" id="passwordError"></span>
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <div class="password-box">
                    <input type="password" id="confirmPassword" disabled
                           oninput="validateConfirmPassword();checkFormValidity()">
                </div>
                <span class="error" id="confirmPasswordError"></span>
            </div>

            <div class="form-group" id="termsContainer">
                <div style="display:flex; margin-top:20px;">
                    <input type="checkbox" id="terms"
                           onchange="validateTerms();checkFormValidity()">
                    <label for="terms">
                        I accept Terms and Conditions
                    </label>
                </div>
                <span class="error" id="termsError"></span>
            </div>

            <button type="submit" id="submitBtn" disabled>Signup</button>
                    
            <p class="link">
                Already have an account?
                <a href="/Account/SignIn">Sign In</a>
            </p>

        </form>
    </div>
    <script src="~/js/signup.js"></script>
</body>
</html>