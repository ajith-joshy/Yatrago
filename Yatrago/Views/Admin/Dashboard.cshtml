@{
    Layout = "_AdminLayout";
}

<h1>
    Dashboard Overview
</h1>

<div class="cards">

<div class="card">
    <h3>Total Users</h3>
    <div class="booking-count">
        @ViewBag.TotalUsers
    </div>
</div>

<div class="card">
    <h3>Total Buses</h3>
    <div class="booking-count">
        @ViewBag.TotalBuses
    </div>
</div>

<div class="card">
    <h3>Total Routes</h3>
    <div class="booking-count">
        @ViewBag.TotalRoutes
    </div>
</div>

<div class="card">
    <h3>Total Bookings</h3>
    <div class="booking-count">
        @ViewBag.TotalBookings
    </div>
</div>

</div>
