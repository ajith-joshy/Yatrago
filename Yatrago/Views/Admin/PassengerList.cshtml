@model List<YatraGo.Models.Passenger>

@{
    Layout = "_AdminLayout";
}

<h1>
    Passenger List
</h1>

<div class="table-container">

    <table class="bus-table">

        <thead>

            <tr>

                <th>Passenger ID</th>

                <th>Name</th>

                <th>Age</th>

                <th>Gender</th>

                <th>Seat Number</th>

            </tr>

        </thead>

        <tbody>

            @if (Model.Count > 0)
            {
                @foreach (var passenger in Model)
                {
                    <tr>

                        <td>
                            @passenger.PassengerId
                        </td>

                        <td>
                            @passenger.PassengerName
                        </td>

                        <td>
                            @passenger.Age
                        </td>

                        <td>
                            @passenger.Gender
                        </td>

                        <td>
                            @passenger.SeatNumber
                        </td>

                    </tr>
                }
            }

            else
            {
                <tr>

                    <td colspan="5">

                        No passengers found.

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>