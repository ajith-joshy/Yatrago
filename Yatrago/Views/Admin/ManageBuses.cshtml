@model List<YatraGo.Models.Bus>

@using YatraGo.Models

@{
    Layout = "_AdminLayout";

    var routes =
    ViewBag.Routes as List<BusRoute>;
}

<div class="bus-page">

    <!-- ADD BUS FORM -->

    <div class="bus-form-section">

        <h2>Add Bus</h2>

        <form method="post"
              enctype="multipart/form-data"
              class="bus-form"
              asp-action="AddBus"
              asp-controller="Admin"
              onsubmit="return validateBusForm()">

            <!-- BUS NAME -->

            <div class="bus-input-group">

                <label>Bus Name</label>

                <input type="text"
                       id="busName"
                       name="BusName">

                <span class="error"
                      id="busNameError">
                </span>

            </div>

            <!-- BUS NUMBER -->

            <div class="bus-input-group">

                <label>Bus Number</label>

                <input type="text"
                       id="busNumber"
                       name="BusNumber">

                <span class="error"
                      id="busNumberError">
                </span>

            </div>

            <!-- BUS TYPE -->

            <div class="bus-input-group">

                <label>Bus Type</label>

                <select id="busType"
                        name="BusType">

                    <option value="">
                        Select Bus Type
                    </option>

                    <option value="AC Sleeper">
                        AC Sleeper
                    </option>

                    <option value="Non-AC Sleeper">
                        Non-AC Sleeper
                    </option>

                    <option value="AC Seater">
                        AC Seater
                    </option>

                    <option value="Non-AC Seater">
                        Non-AC Seater
                    </option>

                </select>

                <span class="error"
                      id="busTypeError">
                </span>

            </div>

            <!-- TOTAL SEATS -->

            <div class="bus-input-group">

                <label>Total Seats</label>

                <input type="text"
                       id="totalSeats"
                       name="TotalSeats">

                <span class="error"
                      id="totalSeatsError">
                </span>

            </div>

            <!-- ROUTE -->

            <div class="bus-input-group">

                <label>Route</label>

                <select id="routeId"
                        name="RouteId">

                    <option value="">
                        Select Route
                    </option>

                    @foreach (var route in routes)
                    {
                        <option value="@route.RouteId">

                            @route.Source
                            →
                            @route.Destination

                        </option>
                    }

                </select>

                <span class="error"
                      id="routeIdError">
                </span>

            </div>

            <!-- DEPARTURE -->

            <div class="bus-input-group">

                <label>Departure Time</label>

                <input type="time"
                       id="departureTime"
                       name="DepartureTime">

                <span class="error"
                      id="departureTimeError">
                </span>

            </div>

            <!-- ARRIVAL -->

            <div class="bus-input-group">

                <label>Arrival Time</label>

                <input type="time"
                       id="arrivalTime"
                       name="ArrivalTime">

                <span class="error"
                      id="arrivalTimeError">
                </span>

            </div>

            <!-- bus image -->
            <div class="bus-input-group">

                <label>
                    Bus Image
                </label>

                <input type="file"
                       name="imageFile"
                       accept=".jpg,.jpeg,.png">

            </div>

            <!-- FARE -->

            <div class="bus-input-group">

                <label>Fare Amount</label>

                <input type="text"
                       id="fareAmount"
                       name="FareAmount">

                <span class="error"
                      id="fareAmountError">
                </span>

            </div>

            <!-- BUTTON -->

            <div class="bus-button-group">

                <button type="submit">
                    Add Bus
                </button>

            </div>

        </form>

    </div>

    <!-- BUS TABLE -->

    <div class="bus-table-section">

        <h2>Added Buses</h2>

        <table>

            <thead>

                <tr>

                    <th>Bus Name</th>

                    <th>Bus Number</th>

                    <th>Type</th>

                    <th>Seats</th>

                    <th>Route</th>

                    <th>Departure</th>

                    <th>Arrival</th>

                    <th>Image</th>

                    <th>Fare</th>

                    <th>Status</th>

                    <th>Actions</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var bus in Model)
                {
                    <tr>

                        <td>
                            @bus.BusName
                        </td>

                        <td>
                            @bus.BusNumber
                        </td>

                        <td>
                            @bus.BusType
                        </td>

                        <td>
                            @bus.TotalSeats
                        </td>

                        <td>

                            @bus.Source
                            →
                            @bus.Destination

                        </td>

                        <td>
                            @bus.DepartureTime
                        </td>

                        <td>
                            @bus.ArrivalTime
                        </td>

                        <td>
                            <button type="button"
                                    class="operations-btn"
                                    onclick="viewBusImage('@Url.Content("~" + bus.BusImage)')">
                                View
                            </button>
                        </td>

                        <td>
                            ₹@bus.FareAmount
                        </td>

                        <td>

                            @(bus.Status
                                ? "Active"
                                : "Inactive")

                        </td>

                        <td>
                        <div class="action-buttons">
                            <a asp-action="EditBus"
                               asp-route-id="@bus.BusId"
                               class="operations-btn">
                                Edit
                            </a>
                            <a asp-action="DeleteBus"
                               asp-route-busId="@bus.BusId"
                               onclick="return confirm('Delete this bus?')"
                               class="operations-btn">
                                Delete
                            </a>
                        </div>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>
@if (TempData["Message"] != null)
{
    <script>
        alert("@TempData["Message"]");
    </script>
}

<!-- IMAGE MODAL -->

<div id="imageModal" class="image-modal">

    <span class="close-modal"
          onclick="closeImageModal()">

        &times;

    </span>

    <img id="modalImage"
         class="modal-image">

</div>
<script src="~/js/addbus.js"></script>

